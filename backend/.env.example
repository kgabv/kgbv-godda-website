# Backend env — copy to backend/.env and fill in values
MONGO_URL=mongodb://localhost:27017
DB_NAME=kgbv_godda
CORS_ORIGINS=*
EMERGENT_LLM_KEY=
APP_NAME=kgbv-godda
# Optional: comma-separated Google account emails allowed as admins
# Leave empty to allow the first-signed-in user to be admin
ADMIN_ALLOWED_EMAILS=
