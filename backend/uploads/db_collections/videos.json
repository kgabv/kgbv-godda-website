[{"title": "77\u0935\u093e\u0901 \u0917\u0923\u0924\u0902\u0924\u094d\u0930 \u0926\u093f\u0935\u0938 \u0938\u092e\u093e\u0930\u094b\u0939 (26 \u091c\u0928\u0935\u0930\u0940 2026)", "youtube_id": "3tNZY3gGf7k", "description": "\u0915\u0938\u094d\u0924\u0942\u0930\u092c\u093e \u0917\u093e\u0902\u0927\u0940 \u092c\u093e\u0932\u093f\u0915\u093e \u0935\u093f\u0926\u094d\u092f\u093e\u0932\u092f, \u0917\u094b\u0921\u094d\u0921\u093e \u092e\u0947\u0902 77\u0935\u093e\u0901 \u0917\u0923\u0924\u0902\u0924\u094d\u0930 \u0926\u093f\u0935\u0938 \u0926\u0947\u0936\u092d\u0915\u094d\u0924\u093f, \u0909\u0924\u094d\u0938\u093e\u0939 \u090f\u0935\u0902 \u0917\u0930\u093f\u092e\u093e\u092e\u092f \u0935\u093e\u0924\u093e\u0935\u0930\u0923 \u092e\u0947\u0902 \u092e\u0928\u093e\u092f\u093e \u0917\u092f\u093e\u0964 \u0915\u093e\u0930\u094d\u092f\u0915\u094d\u0930\u092e \u0915\u093e \u0936\u0941\u092d\u093e\u0930\u0902\u092d \u0927\u094d\u0935\u091c\u093e\u0930\u094b\u0939\u0923, \u0930\u093e\u0937\u094d\u091f\u094d\u0930\u0940\u092f \u0917\u093e\u0928 \u090f\u0935\u0902 \u0930\u093e\u0937\u094d\u091f\u094d\u0930\u0940\u092f \u0938\u0932\u093e\u092e\u0940 \u0915\u0947 \u0938\u093e\u0925 \u0939\u0941\u0906\u0964 \u0907\u0938\u0915\u0947 \u092a\u0936\u094d\u091a\u093e\u0924 \u0935\u093f\u0926\u094d\u092f\u093e\u0932\u092f \u092a\u0930\u093f\u0935\u093e\u0930 \u0928\u0947 \u092d\u093e\u0930\u0924\u0940\u092f \u0938\u0902\u0935\u093f\u0927\u093e\u0928, \u0932\u094b\u0915\u0924\u093e\u0902\u0924\u094d\u0930\u093f\u0915 \u092e\u0942\u0932\u094d\u092f\u094b\u0902 \u090f\u0935\u0902 \u0930\u093e\u0937\u094d\u091f\u094d\u0930 \u0915\u0940 \u090f\u0915\u0924\u093e \u0914\u0930 \u0905\u0916\u0902\u0921\u0924\u093e \u0915\u0947 \u092a\u094d\u0930\u0924\u093f \u0905\u092a\u0928\u0940 \u092a\u094d\u0930\u0924\u093f\u092c\u0926\u094d\u0927\u0924\u093e \u0935\u094d\u092f\u0915\u094d\u0924 \u0915\u0940\u0964\n\u0915\u093e\u0930\u094d\u092f\u0915\u094d\u0930\u092e \u092e\u0947\u0902 \u091b\u093e\u0924\u094d\u0930\u093e\u0913\u0902 \u0926\u094d\u0935\u093e\u0930\u093e \u0926\u0947\u0936\u092d\u0915\u094d\u0924\u093f \u0917\u0940\u0924, \u0938\u092e\u0942\u0939 \u0928\u0943\u0924\u094d\u092f, \u092d\u093e\u0937\u0923, \u0915\u0935\u093f\u0924\u093e-\u092a\u093e\u0920 \u090f\u0935\u0902 \u0938\u093e\u0902\u0938\u094d\u0915\u0943\u0924\u093f\u0915 \u092a\u094d\u0930\u0938\u094d\u0924\u0941\u0924\u093f\u092f\u093e\u0901 \u0926\u0940 \u0917\u0908\u0902, \u091c\u093f\u0928\u094d\u0939\u094b\u0902\u0928\u0947 \u0909\u092a\u0938\u094d\u0925\u093f\u0924 \u0938\u092d\u0940 \u0905\u0924\u093f\u0925\u093f\u092f\u094b\u0902 \u090f\u0935\u0902 \u0905\u092d\u093f\u092d\u093e\u0935\u0915\u094b\u0902 \u0915\u093e \u092e\u0928 \u092e\u094b\u0939 \u0932\u093f\u092f\u093e\u0964 \u091b\u093e\u0924\u094d\u0930\u093e\u0913\u0902 \u0928\u0947 \u0905\u092a\u0928\u0947 \u092a\u094d\u0930\u0926\u0930\u094d\u0936\u0928 \u0915\u0947 \u092e\u093e\u0927\u094d\u092f\u092e \u0938\u0947 \u0926\u0947\u0936\u092a\u094d\u0930\u0947\u092e, \u0905\u0928\u0941\u0936\u093e\u0938\u0928, \u0928\u093e\u0930\u0940 \u0938\u0936\u0915\u094d\u0924\u093f\u0915\u0930\u0923 \u090f\u0935\u0902 \u0930\u093e\u0937\u094d\u091f\u094d\u0930\u0940\u092f \u090f\u0915\u0924\u093e \u0915\u093e \u0938\u0902\u0926\u0947\u0936 \u0926\u093f\u092f\u093e\u0964\n\u0907\u0938 \u0905\u0935\u0938\u0930 \u092a\u0930 \u0935\u093f\u0926\u094d\u092f\u093e\u0932\u092f \u0915\u0940 \u0935\u093e\u0930\u094d\u0921\u0947\u0928 \u0938\u0939 \u0935\u093f\u091c\u094d\u091e\u093e\u0928 \u0936\u093f\u0915\u094d\u0937\u093f\u0915\u093e \u0936\u094d\u0930\u0940\u092e\u0924\u0940 \u0938\u094d\u0928\u0947\u0939\u0932\u0924\u093e \u0915\u0941\u092e\u093e\u0930\u0940 \u0924\u0925\u093e \u0905\u0928\u094d\u092f \u0936\u093f\u0915\u094d\u0937\u0915\u094b\u0902 \u0928\u0947 \u091b\u093e\u0924\u094d\u0930\u093e\u0913\u0902 \u0915\u094b \u0938\u0902\u0935\u093f\u0927\u093e\u0928 \u0915\u0947 \u0906\u0926\u0930\u094d\u0936\u094b\u0902, \u0915\u0930\u094d\u0924\u0935\u094d\u092f\u094b\u0902 \u090f\u0935\u0902 \u0905\u0927\u093f\u0915\u093e\u0930\u094b\u0902 \u0915\u0947 \u092a\u094d\u0930\u0924\u093f \u091c\u093e\u0917\u0930\u0942\u0915 \u0930\u0939\u0928\u0947 \u0924\u0925\u093e \u0930\u093e\u0937\u094d\u091f\u094d\u0930 \u0928\u093f\u0930\u094d\u092e\u093e\u0923 \u092e\u0947\u0902 \u0938\u0915\u094d\u0930\u093f\u092f \u092d\u0942\u092e\u093f\u0915\u093e \u0928\u093f\u092d\u093e\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f \u092a\u094d\u0930\u0947\u0930\u093f\u0924 \u0915\u093f\u092f\u093e\u0964\n\u0935\u0930\u094d\u0937 2026 \u0915\u0947 \u0930\u093e\u0937\u094d\u091f\u094d\u0930\u0940\u092f \u0917\u0923\u0924\u0902\u0924\u094d\u0930 \u0926\u093f\u0935\u0938 \u0938\u092e\u093e\u0930\u094b\u0939 \u0915\u093e \u092a\u094d\u0930\u092e\u0941\u0916 \u0935\u093f\u0937\u092f \"\u0935\u0902\u0926\u0947 \u092e\u093e\u0924\u0930\u092e\u094d \u0915\u0947 150 \u0935\u0930\u094d\u0937\" \u0930\u0939\u093e, \u091c\u093f\u0938\u0915\u0947 \u092e\u093e\u0927\u094d\u092f\u092e \u0938\u0947 \u0930\u093e\u0937\u094d\u091f\u094d\u0930\u092d\u0915\u094d\u0924\u093f, \u0938\u093e\u0902\u0938\u094d\u0915\u0943\u0924\u093f\u0915 \u0935\u093f\u0930\u093e\u0938\u0924 \u0914\u0930 \u0938\u0902\u0935\u093f\u0927\u093e\u0928 \u0915\u0947 \u092a\u094d\u0930\u0924\u093f \u0938\u092e\u094d\u092e\u093e\u0928 \u0915\u093e \u0938\u0902\u0926\u0947\u0936 \u092a\u0942\u0930\u0947 \u0926\u0947\u0936 \u092e\u0947\u0902 \u0926\u093f\u092f\u093e \u0917\u092f\u093e\u0964 \ufffd\nPress Information Bureau +1\n\u0915\u093e\u0930\u094d\u092f\u0915\u094d\u0930\u092e \u0915\u0947 \u0905\u0902\u0924 \u092e\u0947\u0902 \u0938\u092d\u0940 \u091b\u093e\u0924\u094d\u0930\u093e\u0913\u0902, \u0936\u093f\u0915\u094d\u0937\u0915\u094b\u0902 \u090f\u0935\u0902 \u0915\u0930\u094d\u092e\u091a\u093e\u0930\u093f\u092f\u094b\u0902 \u0915\u0947 \u092c\u0940\u091a \u092e\u093f\u0920\u093e\u0907\u092f\u094b\u0902 \u0915\u093e \u0935\u093f\u0924\u0930\u0923 \u0915\u093f\u092f\u093e \u0917\u092f\u093e \u0924\u0925\u093e \u0930\u093e\u0937\u094d\u091f\u094d\u0930\u0917\u093e\u0928 \u0915\u0947 \u0938\u093e\u0925 \u0938\u092e\u093e\u0930\u094b\u0939 \u0915\u093e \u0938\u092b\u0932 \u0938\u092e\u093e\u092a\u0928 \u0939\u0941\u0906\u0964 \u0935\u093f\u0926\u094d\u092f\u093e\u0932\u092f \u092a\u0930\u093f\u0935\u093e\u0930 \u0928\u0947 \u092d\u093e\u0930\u0924 \u0915\u0947 \u0909\u091c\u094d\u091c\u094d\u0935\u0932 \u092d\u0935\u093f\u0937\u094d\u092f, \u0930\u093e\u0937\u094d\u091f\u094d\u0930\u0940\u092f \u090f\u0915\u0924\u093e \u090f\u0935\u0902 \u0938\u092e\u0943\u0926\u094d\u0927\u093f \u0915\u0947 \u0932\u093f\u090f \u0905\u092a\u0928\u0940 \u0936\u0941\u092d\u0915\u093e\u092e\u0928\u093e\u090f\u0901 \u0935\u094d\u092f\u0915\u094d\u0924 \u0915\u0930\u0924\u0947 \u0939\u0941\u090f \"\u091c\u092f \u0939\u093f\u0902\u0926! \u0935\u0902\u0926\u0947 \u092e\u093e\u0924\u0930\u092e\u094d!\" \u0915\u093e \u0909\u0926\u094d\u0918\u094b\u0937 \u0915\u093f\u092f\u093e\u0964", "category": "General", "id": "b75a791b-dfb6-4a63-b525-ba3721c03ad3", "created_at": "2026-07-21T17:45:02.030754+00:00"}, {"title": "\u092c\u0938\u0902\u0924 \u092a\u0902\u091a\u092e\u0940 KGBV Godda (2026)", "youtube_id": "G65TuS5l21E", "description": "\u0926\u093f\u0928\u093e\u0902\u0915 23 \u091c\u0928\u0935\u0930\u0940 2026 \u0915\u094b \u0935\u093f\u0926\u094d\u092f\u093e\u0932\u092f \u092e\u0947\u0902 \u092c\u0938\u0902\u0924 \u092a\u0902\u091a\u092e\u0940 \u0915\u093e \u092a\u0930\u094d\u0935 \u0939\u0930\u094d\u0937\u094b\u0932\u094d\u0932\u093e\u0938 \u090f\u0935\u0902 \u0936\u094d\u0930\u0926\u094d\u0927\u093e \u0915\u0947 \u0938\u093e\u0925 \u092e\u0928\u093e\u092f\u093e \u0917\u092f\u093e\u0964 \u0915\u093e\u0930\u094d\u092f\u0915\u094d\u0930\u092e \u0915\u093e \u0936\u0941\u092d\u093e\u0930\u0902\u092d \u092e\u093e\u0901 \u0938\u0930\u0938\u094d\u0935\u0924\u0940 \u0915\u0947 \u091a\u093f\u0924\u094d\u0930 \u092a\u0930 \u092a\u0941\u0937\u094d\u092a \u0905\u0930\u094d\u092a\u093f\u0924 \u090f\u0935\u0902 \u0926\u0940\u092a \u092a\u094d\u0930\u091c\u094d\u0935\u0932\u093f\u0924 \u0915\u0930 \u0915\u093f\u092f\u093e \u0917\u092f\u093e\u0964 \u0924\u0924\u094d\u092a\u0936\u094d\u091a\u093e\u0924 \u0936\u093f\u0915\u094d\u0937\u0915\u094b\u0902 \u090f\u0935\u0902 \u091b\u093e\u0924\u094d\u0930\u093e\u0913\u0902 \u0926\u094d\u0935\u093e\u0930\u093e \u092e\u093e\u0901 \u0938\u0930\u0938\u094d\u0935\u0924\u0940 \u0915\u0940 \u0935\u0902\u0926\u0928\u093e \u092a\u094d\u0930\u0938\u094d\u0924\u0941\u0924 \u0915\u0940 \u0917\u0908\u0964\n\u0907\u0938 \u0905\u0935\u0938\u0930 \u092a\u0930 \u091b\u093e\u0924\u094d\u0930\u093e\u0913\u0902 \u0928\u0947 \u0917\u0940\u0924, \u0915\u0935\u093f\u0924\u093e, \u092d\u093e\u0937\u0923 \u090f\u0935\u0902 \u0938\u093e\u0902\u0938\u094d\u0915\u0943\u0924\u093f\u0915 \u0915\u093e\u0930\u094d\u092f\u0915\u094d\u0930\u092e\u094b\u0902 \u0915\u0947 \u092e\u093e\u0927\u094d\u092f\u092e \u0938\u0947 \u091c\u094d\u091e\u093e\u0928, \u0936\u093f\u0915\u094d\u0937\u093e \u090f\u0935\u0902 \u0938\u0902\u0938\u094d\u0915\u0943\u0924\u093f \u0915\u0947 \u092e\u0939\u0924\u094d\u0935 \u0915\u094b \u092a\u094d\u0930\u0938\u094d\u0924\u0941\u0924 \u0915\u093f\u092f\u093e\u0964 \u0935\u093f\u0926\u094d\u092f\u093e\u0932\u092f \u0915\u0947 \u0936\u093f\u0915\u094d\u0937\u0915\u094b\u0902 \u0928\u0947 \u091b\u093e\u0924\u094d\u0930\u093e\u0913\u0902 \u0915\u094b \u092c\u0938\u0902\u0924 \u092a\u0902\u091a\u092e\u0940 \u0915\u0947 \u0927\u093e\u0930\u094d\u092e\u093f\u0915, \u0938\u093e\u0902\u0938\u094d\u0915\u0943\u0924\u093f\u0915 \u090f\u0935\u0902 \u0936\u0948\u0915\u094d\u0937\u093f\u0915 \u092e\u0939\u0924\u094d\u0935 \u0915\u0940 \u091c\u093e\u0928\u0915\u093e\u0930\u0940 \u0926\u0940 \u0924\u0925\u093e \u0909\u0928\u094d\u0939\u0947\u0902 \u0936\u093f\u0915\u094d\u0937\u093e, \u0905\u0928\u0941\u0936\u093e\u0938\u0928 \u090f\u0935\u0902 \u0928\u0948\u0924\u093f\u0915 \u092e\u0942\u0932\u094d\u092f\u094b\u0902 \u0915\u093e \u092a\u093e\u0932\u0928 \u0915\u0930\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f \u092a\u094d\u0930\u0947\u0930\u093f\u0924 \u0915\u093f\u092f\u093e\u0964\n\u0915\u093e\u0930\u094d\u092f\u0915\u094d\u0930\u092e \u0915\u0947 \u0905\u0902\u0924 \u092e\u0947\u0902 \u0938\u092d\u0940 \u091b\u093e\u0924\u094d\u0930\u093e\u0913\u0902 \u090f\u0935\u0902 \u0936\u093f\u0915\u094d\u0937\u0915\u094b\u0902 \u0928\u0947 \u092e\u093e\u0901 \u0938\u0930\u0938\u094d\u0935\u0924\u0940 \u0938\u0947 \u091c\u094d\u091e\u093e\u0928, \u0935\u093f\u0935\u0947\u0915 \u090f\u0935\u0902 \u0909\u091c\u094d\u091c\u094d\u0935\u0932 \u092d\u0935\u093f\u0937\u094d\u092f \u0915\u0940 \u0915\u093e\u092e\u0928\u093e \u0915\u0940\u0964 \u092a\u0942\u0930\u0947 \u0935\u093f\u0926\u094d\u092f\u093e\u0932\u092f \u092a\u0930\u093f\u0938\u0930 \u092e\u0947\u0902 \u0909\u0924\u094d\u0938\u093e\u0939, \u0936\u094d\u0930\u0926\u094d\u0927\u093e \u090f\u0935\u0902 \u0906\u0928\u0902\u0926 \u0915\u093e \u0935\u093e\u0924\u093e\u0935\u0930\u0923 \u092c\u0928\u093e \u0930\u0939\u093e\u0964", "category": "General", "id": "7123d716-9d1e-4a7e-b86c-b971f8f4036f", "created_at": "2026-07-21T17:49:27.327001+00:00"}, {"title": "\u092e\u093e\u0901 \u0938\u0930\u0938\u094d\u0935\u0924\u0940 \u092a\u094d\u0930\u0924\u093f\u092e\u093e \u0935\u093f\u0938\u0930\u094d\u091c\u0928 \u0915\u093e\u0930\u094d\u092f\u0915\u094d\u0930\u092e (2026))", "youtube_id": "vJwYqHV6GcE", "description": "\u092c\u0938\u0902\u0924 \u092a\u0902\u091a\u092e\u0940 \u092e\u0939\u094b\u0924\u094d\u0938\u0935 \u0915\u0947 \u0909\u092a\u0930\u093e\u0902\u0924 \u0935\u093f\u0926\u094d\u092f\u093e\u0932\u092f \u092e\u0947\u0902 \u092e\u093e\u0901 \u0938\u0930\u0938\u094d\u0935\u0924\u0940 \u0915\u0940 \u092a\u094d\u0930\u0924\u093f\u092e\u093e \u0915\u093e \u0935\u093f\u0938\u0930\u094d\u091c\u0928 \u0936\u094d\u0930\u0926\u094d\u0927\u093e \u090f\u0935\u0902 \u092d\u0915\u094d\u0924\u093f \u092d\u093e\u0935 \u0915\u0947 \u0938\u093e\u0925 \u0938\u0902\u092a\u0928\u094d\u0928 \u0915\u0930\u093e\u092f\u093e \u0917\u092f\u093e\u0964 \u0915\u093e\u0930\u094d\u092f\u0915\u094d\u0930\u092e \u092e\u0947\u0902 \u0935\u093f\u0926\u094d\u092f\u093e\u0932\u092f \u0915\u0947 \u0938\u092d\u0940 \u0936\u093f\u0915\u094d\u0937\u0915, \u0936\u093f\u0915\u094d\u0937\u093f\u0915\u093e\u090f\u0901, \u0915\u0930\u094d\u092e\u091a\u093e\u0930\u0940 \u090f\u0935\u0902 \u091b\u093e\u0924\u094d\u0930\u093e\u090f\u0901 \u0909\u092a\u0938\u094d\u0925\u093f\u0924 \u0930\u0939\u0940\u0902\u0964\n\u092a\u094d\u0930\u0924\u093f\u092e\u093e \u0935\u093f\u0938\u0930\u094d\u091c\u0928 \u0938\u0947 \u092a\u0942\u0930\u094d\u0935 \u092e\u093e\u0901 \u0938\u0930\u0938\u094d\u0935\u0924\u0940 \u0915\u0940 \u0935\u093f\u0927\u093f\u0935\u0924 \u0906\u0930\u0924\u0940 \u090f\u0935\u0902 \u092a\u0942\u091c\u093e-\u0905\u0930\u094d\u091a\u0928\u093e \u0915\u0940 \u0917\u0908\u0964 \u0907\u0938\u0915\u0947 \u092a\u0936\u094d\u091a\u093e\u0924 \u0938\u092d\u0940 \u0928\u0947 \u092e\u093e\u0901 \u0938\u0930\u0938\u094d\u0935\u0924\u0940 \u0938\u0947 \u091c\u094d\u091e\u093e\u0928, \u092c\u0941\u0926\u094d\u0927\u093f, \u0935\u093f\u0935\u0947\u0915 \u090f\u0935\u0902 \u0909\u091c\u094d\u091c\u094d\u0935\u0932 \u092d\u0935\u093f\u0937\u094d\u092f \u0915\u0940 \u0915\u093e\u092e\u0928\u093e \u0915\u0930\u0924\u0947 \u0939\u0941\u090f \u092d\u093e\u0935\u092a\u0942\u0930\u094d\u0923 \u0935\u093f\u0926\u093e\u0908 \u0926\u0940\u0964 \u091b\u093e\u0924\u094d\u0930\u093e\u0913\u0902 \u0928\u0947 \u092d\u0915\u094d\u0924\u093f \u0917\u0940\u0924 \u090f\u0935\u0902 \u091c\u092f\u0918\u094b\u0937 \u0915\u0947 \u0938\u093e\u0925 \u0909\u0924\u094d\u0938\u093e\u0939\u092a\u0942\u0930\u094d\u0935\u0915 \u0935\u093f\u0938\u0930\u094d\u091c\u0928 \u092f\u093e\u0924\u094d\u0930\u093e \u092e\u0947\u0902 \u0938\u0939\u092d\u093e\u0917\u093f\u0924\u093e \u0915\u0940\u0964\n\u0915\u093e\u0930\u094d\u092f\u0915\u094d\u0930\u092e \u0936\u093e\u0902\u0924\u093f\u092a\u0942\u0930\u094d\u0923 \u090f\u0935\u0902 \u0938\u0941\u0930\u0915\u094d\u0937\u093f\u0924 \u0935\u093e\u0924\u093e\u0935\u0930\u0923 \u092e\u0947\u0902 \u0938\u0902\u092a\u0928\u094d\u0928 \u0939\u0941\u0906\u0964 \u0905\u0902\u0924 \u092e\u0947\u0902 \u0938\u092d\u0940 \u0928\u0947 \u092f\u0939 \u0938\u0902\u0915\u0932\u094d\u092a \u0932\u093f\u092f\u093e \u0915\u093f \u092a\u094d\u0930\u093e\u092a\u094d\u0924 \u091c\u094d\u091e\u093e\u0928 \u090f\u0935\u0902 \u0938\u0902\u0938\u094d\u0915\u093e\u0930\u094b\u0902 \u0915\u094b \u0905\u092a\u0928\u0947 \u091c\u0940\u0935\u0928 \u092e\u0947\u0902 \u0905\u092a\u0928\u093e\u0915\u0930 \u0938\u092e\u093e\u091c \u090f\u0935\u0902 \u0930\u093e\u0937\u094d\u091f\u094d\u0930 \u0915\u0947 \u0935\u093f\u0915\u093e\u0938 \u092e\u0947\u0902 \u092f\u094b\u0917\u0926\u093e\u0928 \u0926\u0947\u0902\u0917\u0947\u0964", "category": "General", "id": "cc6775b8-7211-44be-8697-a845e436b648", "created_at": "2026-07-21T17:51:43.064412+00:00"}, {"title": "\u0917\u094b\u0921\u094d\u0921\u093e \u091f\u093e\u0909\u0928\u0939\u0949\u0932 \u092e\u0947\u0902 \u0906\u092f\u094b\u091c\u093f\u0924 \u0926\u0947\u0936\u092d\u0915\u094d\u0924\u093f \u0915\u093e\u0930\u094d\u092f\u0915\u094d\u0930\u092e (2026)", "youtube_id": "i_0mwKWVegE", "description": "\u0935\u0930\u094d\u0937 2026 \u092e\u0947\u0902 \u0917\u094b\u0921\u094d\u0921\u093e \u091f\u093e\u0909\u0928\u0939\u0949\u0932 \u092e\u0947\u0902 \u0906\u092f\u094b\u091c\u093f\u0924 \u0926\u0947\u0936\u092d\u0915\u094d\u0924\u093f \u0938\u093e\u0902\u0938\u094d\u0915\u0943\u0924\u093f\u0915 \u0915\u093e\u0930\u094d\u092f\u0915\u094d\u0930\u092e \u092e\u0947\u0902 \u0935\u093f\u0926\u094d\u092f\u093e\u0932\u092f \u0915\u0940 \u091b\u093e\u0924\u094d\u0930\u093e\u0913\u0902 \u0928\u0947 \u0909\u0924\u094d\u0938\u093e\u0939\u092a\u0942\u0930\u094d\u0935\u0915 \u0938\u0939\u092d\u093e\u0917\u093f\u0924\u093e \u0915\u0940\u0964 \u0915\u093e\u0930\u094d\u092f\u0915\u094d\u0930\u092e \u0915\u093e \u0909\u0926\u094d\u0926\u0947\u0936\u094d\u092f \u091b\u093e\u0924\u094d\u0930\u093e\u0913\u0902 \u092e\u0947\u0902 \u0930\u093e\u0937\u094d\u091f\u094d\u0930\u092d\u0915\u094d\u0924\u093f, \u0930\u093e\u0937\u094d\u091f\u094d\u0930\u0940\u092f \u090f\u0915\u0924\u093e \u090f\u0935\u0902 \u0938\u093e\u0902\u0938\u094d\u0915\u0943\u0924\u093f\u0915 \u092e\u0942\u0932\u094d\u092f\u094b\u0902 \u0915\u0940 \u092d\u093e\u0935\u0928\u093e \u0915\u093e \u0935\u093f\u0915\u093e\u0938 \u0915\u0930\u0928\u093e \u0925\u093e\u0964\n\u0915\u093e\u0930\u094d\u092f\u0915\u094d\u0930\u092e \u092e\u0947\u0902 \u091b\u093e\u0924\u094d\u0930\u093e\u0913\u0902 \u0928\u0947 \u0926\u0947\u0936\u092d\u0915\u094d\u0924\u093f \u0917\u0940\u0924, \u0938\u092e\u0942\u0939 \u0928\u0943\u0924\u094d\u092f \u090f\u0935\u0902 \u0938\u093e\u0902\u0938\u094d\u0915\u0943\u0924\u093f\u0915 \u092a\u094d\u0930\u0938\u094d\u0924\u0941\u0924\u093f\u092f\u094b\u0902 \u0915\u0947 \u092e\u093e\u0927\u094d\u092f\u092e \u0938\u0947 \u092d\u093e\u0930\u0924 \u0915\u0940 \u0917\u094c\u0930\u0935\u0936\u093e\u0932\u0940 \u0938\u0902\u0938\u094d\u0915\u0943\u0924\u093f, \u0938\u094d\u0935\u0924\u0902\u0924\u094d\u0930\u0924\u093e \u0938\u0947\u0928\u093e\u0928\u093f\u092f\u094b\u0902 \u0915\u0947 \u0924\u094d\u092f\u093e\u0917 \u0924\u0925\u093e \u0930\u093e\u0937\u094d\u091f\u094d\u0930\u0940\u092f \u090f\u0915\u0924\u093e \u0915\u093e \u092a\u094d\u0930\u092d\u093e\u0935\u0936\u093e\u0932\u0940 \u092a\u094d\u0930\u0926\u0930\u094d\u0936\u0928 \u0915\u093f\u092f\u093e\u0964 \u0909\u092a\u0938\u094d\u0925\u093f\u0924 \u0926\u0930\u094d\u0936\u0915\u094b\u0902 \u090f\u0935\u0902 \u0905\u0924\u093f\u0925\u093f\u092f\u094b\u0902 \u0928\u0947 \u091b\u093e\u0924\u094d\u0930\u093e\u0913\u0902 \u0915\u0940 \u092e\u0928\u092e\u094b\u0939\u0915 \u092a\u094d\u0930\u0938\u094d\u0924\u0941\u0924\u093f \u0915\u0940 \u0938\u0930\u093e\u0939\u0928\u093e \u0915\u0940\u0964\n\u0907\u0938 \u0905\u0935\u0938\u0930 \u092a\u0930 \u091b\u093e\u0924\u094d\u0930\u093e\u0913\u0902 \u0915\u094b \u0905\u0928\u0941\u0936\u093e\u0938\u0928, \u0906\u0924\u094d\u092e\u0935\u093f\u0936\u094d\u0935\u093e\u0938, \u091f\u0940\u092e \u092d\u093e\u0935\u0928\u093e \u090f\u0935\u0902 \u0930\u093e\u0937\u094d\u091f\u094d\u0930 \u0915\u0947 \u092a\u094d\u0930\u0924\u093f \u0905\u092a\u0928\u0947 \u0915\u0930\u094d\u0924\u0935\u094d\u092f\u094b\u0902 \u0915\u093e \u0928\u093f\u0930\u094d\u0935\u0939\u0928 \u0915\u0930\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f \u092a\u094d\u0930\u0947\u0930\u093f\u0924 \u0915\u093f\u092f\u093e \u0917\u092f\u093e\u0964 \u0915\u093e\u0930\u094d\u092f\u0915\u094d\u0930\u092e \u0938\u092b\u0932\u0924\u093e\u092a\u0942\u0930\u094d\u0935\u0915 \u090f\u0935\u0902 \u0909\u0924\u094d\u0938\u093e\u0939\u092a\u0942\u0930\u094d\u0923 \u0935\u093e\u0924\u093e\u0935\u0930\u0923 \u092e\u0947\u0902 \u0938\u0902\u092a\u0928\u094d\u0928 \u0939\u0941\u0906 \u0924\u0925\u093e \u091b\u093e\u0924\u094d\u0930\u093e\u0913\u0902 \u0928\u0947 \u0935\u093f\u0926\u094d\u092f\u093e\u0932\u092f \u0915\u093e \u0917\u094c\u0930\u0935 \u092c\u0922\u093c\u093e\u092f\u093e\u0964", "category": "General", "id": "3cf80cdf-d9f4-4fcd-b001-e5a4b276d1dd", "created_at": "2026-07-21T17:54:22.192262+00:00"}, {"title": "\u0917\u093e\u0901\u0935-\u0917\u093e\u0901\u0935 \u0936\u093f\u0915\u094d\u0937\u093e \u091c\u093e\u0917\u0930\u0942\u0915\u0924\u093e \u090f\u0935\u0902 \u0928\u093e\u092e\u093e\u0902\u0915\u0928 \u092d\u094d\u0930\u092e\u0923 \u0915\u093e\u0930\u094d\u092f\u0915\u094d\u0930\u092e (2026)", "youtube_id": "4UuiihaiPeU", "description": "\u0935\u0930\u094d\u0937 2026 \u092e\u0947\u0902 \u0935\u093f\u0926\u094d\u092f\u093e\u0932\u092f \u0926\u094d\u0935\u093e\u0930\u093e \"\u0917\u093e\u0901\u0935-\u0917\u093e\u0901\u0935 \u0936\u093f\u0915\u094d\u0937\u093e \u091c\u093e\u0917\u0930\u0942\u0915\u0924\u093e \u090f\u0935\u0902 \u0928\u093e\u092e\u093e\u0902\u0915\u0928 \u0905\u092d\u093f\u092f\u093e\u0928\" \u0915\u0947 \u0905\u0902\u0924\u0930\u094d\u0917\u0924 \u0935\u093f\u092d\u093f\u0928\u094d\u0928 \u0917\u093e\u0901\u0935\u094b\u0902 \u0915\u093e \u092d\u094d\u0930\u092e\u0923 \u0915\u093f\u092f\u093e \u0917\u092f\u093e\u0964 \u0907\u0938 \u0905\u092d\u093f\u092f\u093e\u0928 \u092e\u0947\u0902 \u0935\u093f\u0926\u094d\u092f\u093e\u0932\u092f \u0915\u0947 \u0936\u093f\u0915\u094d\u0937\u0915-\u0936\u093f\u0915\u094d\u0937\u093f\u0915\u093e\u0913\u0902 \u090f\u0935\u0902 \u091b\u093e\u0924\u094d\u0930\u093e\u0913\u0902 \u0928\u0947 \u0938\u0915\u094d\u0930\u093f\u092f \u0930\u0942\u092a \u0938\u0947 \u092d\u093e\u0917 \u0932\u093f\u092f\u093e\u0964\n\n\u092d\u094d\u0930\u092e\u0923 \u0915\u0947 \u0926\u094c\u0930\u093e\u0928 \u0905\u092d\u093f\u092d\u093e\u0935\u0915\u094b\u0902 \u090f\u0935\u0902 \u0917\u094d\u0930\u093e\u092e\u0940\u0923\u094b\u0902 \u0915\u094b \u092c\u093e\u0932\u093f\u0915\u093e \u0936\u093f\u0915\u094d\u0937\u093e \u0915\u0947 \u092e\u0939\u0924\u094d\u0935, \u0928\u093f\u092f\u092e\u093f\u0924 \u0935\u093f\u0926\u094d\u092f\u093e\u0932\u092f \u0909\u092a\u0938\u094d\u0925\u093f\u0924\u093f, \u0928\u093f\u0903\u0936\u0941\u0932\u094d\u0915 \u0906\u0935\u093e\u0938\u0940\u092f \u0936\u093f\u0915\u094d\u0937\u093e, \u0917\u0941\u0923\u0935\u0924\u094d\u0924\u093e\u092a\u0942\u0930\u094d\u0923 \u0936\u093f\u0915\u094d\u0937\u0923, \u091b\u093e\u0924\u094d\u0930\u093e\u0935\u093e\u0938, \u092a\u0941\u0938\u094d\u0924\u0915\u0947\u0902, \u0935\u0930\u094d\u0926\u0940, \u092d\u094b\u091c\u0928 \u0924\u0925\u093e \u0905\u0928\u094d\u092f \u0938\u0930\u0915\u093e\u0930\u0940 \u0938\u0941\u0935\u093f\u0927\u093e\u0913\u0902 \u0915\u0940 \u091c\u093e\u0928\u0915\u093e\u0930\u0940 \u0926\u0940 \u0917\u0908\u0964 \u0938\u093e\u0925 \u0939\u0940 \u0935\u093f\u0926\u094d\u092f\u093e\u0932\u092f \u0938\u0947 \u092c\u093e\u0939\u0930 \u092f\u093e \u092a\u0922\u093c\u093e\u0908 \u091b\u094b\u0921\u093c \u091a\u0941\u0915\u0940 \u092c\u093e\u0932\u093f\u0915\u093e\u0913\u0902 \u0915\u093e \u0928\u093e\u092e\u093e\u0902\u0915\u0928 \u0915\u0930\u093e\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f \u092a\u094d\u0930\u0947\u0930\u093f\u0924 \u0915\u093f\u092f\u093e \u0917\u092f\u093e\u0964\n\n\u0907\u0938 \u0905\u092d\u093f\u092f\u093e\u0928 \u0915\u0947 \u092e\u093e\u0927\u094d\u092f\u092e \u0938\u0947 \u0932\u094b\u0917\u094b\u0902 \u092e\u0947\u0902 \u092c\u093e\u0932\u093f\u0915\u093e \u0936\u093f\u0915\u094d\u0937\u093e \u0915\u0947 \u092a\u094d\u0930\u0924\u093f \u091c\u093e\u0917\u0930\u0942\u0915\u0924\u093e \u092c\u0922\u093c\u0940 \u0924\u0925\u093e \u0905\u0927\u093f\u0915 \u0938\u0947 \u0905\u0927\u093f\u0915 \u092f\u094b\u0917\u094d\u092f \u092c\u093e\u0932\u093f\u0915\u093e\u0913\u0902 \u0915\u093e \u0935\u093f\u0926\u094d\u092f\u093e\u0932\u092f \u092e\u0947\u0902 \u0928\u093e\u092e\u093e\u0902\u0915\u0928 \u0938\u0941\u0928\u093f\u0936\u094d\u091a\u093f\u0924 \u0915\u0930\u0928\u0947 \u0915\u093e \u092a\u094d\u0930\u092f\u093e\u0938 \u0915\u093f\u092f\u093e \u0917\u092f\u093e\u0964 \u0915\u093e\u0930\u094d\u092f\u0915\u094d\u0930\u092e \u0938\u092b\u0932\u0924\u093e\u092a\u0942\u0930\u094d\u0935\u0915 \u0938\u0902\u092a\u0928\u094d\u0928 \u0939\u0941\u0906 \u0914\u0930 \u0917\u094d\u0930\u093e\u092e\u0940\u0923\u094b\u0902 \u0928\u0947 \u0907\u0938 \u092a\u0939\u0932 \u0915\u0940 \u0938\u0930\u093e\u0939\u0928\u093e \u0915\u0930\u0924\u0947 \u0939\u0941\u090f \u092c\u093e\u0932\u093f\u0915\u093e\u0913\u0902 \u0915\u094b \u0935\u093f\u0926\u094d\u092f\u093e\u0932\u092f \u092d\u0947\u091c\u0928\u0947 \u0915\u093e \u0906\u0936\u094d\u0935\u093e\u0938\u0928 \u0926\u093f\u092f\u093e\u0964", "category": "General", "id": "4dd4ffbb-2934-4452-b6ea-23457f5160d0", "created_at": "2026-07-21T17:57:16.044809+00:00"}, {"title": "\u092e\u0939\u093e\u0935\u0940\u0930 \u091c\u092f\u0902\u0924\u0940 2026 \u092a\u0930 \u0906\u092f\u094b\u091c\u093f\u0924 \u0915\u093e\u0930\u094d\u092f\u0915\u094d\u0930\u092e", "youtube_id": "IEP1OeWnffA", "description": "\u0926\u093f\u0928\u093e\u0902\u0915 31 \u092e\u093e\u0930\u094d\u091a 2026 \u0915\u094b \u0915\u0938\u094d\u0924\u0942\u0930\u092c\u093e \u0917\u093e\u0902\u0927\u0940 \u092c\u093e\u0932\u093f\u0915\u093e \u0935\u093f\u0926\u094d\u092f\u093e\u0932\u092f, \u0917\u094b\u0921\u094d\u0921\u093e \u092e\u0947\u0902 \u092d\u0917\u0935\u093e\u0928 \u092e\u0939\u093e\u0935\u0940\u0930 \u091c\u092f\u0902\u0924\u0940 \u0936\u094d\u0930\u0926\u094d\u0927\u093e \u090f\u0935\u0902 \u0909\u0924\u094d\u0938\u093e\u0939 \u0915\u0947 \u0938\u093e\u0925 \u092e\u0928\u093e\u0908 \u0917\u0908\u0964 \u0915\u093e\u0930\u094d\u092f\u0915\u094d\u0930\u092e \u0915\u093e \u0936\u0941\u092d\u093e\u0930\u0902\u092d \u092d\u0917\u0935\u093e\u0928 \u092e\u0939\u093e\u0935\u0940\u0930 \u0915\u0947 \u091a\u093f\u0924\u094d\u0930 \u092a\u0930 \u092a\u0941\u0937\u094d\u092a \u0905\u0930\u094d\u092a\u093f\u0924 \u090f\u0935\u0902 \u0926\u0940\u092a \u092a\u094d\u0930\u091c\u094d\u0935\u0932\u093f\u0924 \u0915\u0930 \u0915\u093f\u092f\u093e \u0917\u092f\u093e\u0964 \u0907\u0938 \u0905\u0935\u0938\u0930 \u092a\u0930 \u0935\u093f\u0926\u094d\u092f\u093e\u0932\u092f \u0915\u0940 \u0935\u093e\u0930\u094d\u0921\u0947\u0928, \u0936\u093f\u0915\u094d\u0937\u093f\u0915\u093e\u0913\u0902 \u090f\u0935\u0902 \u091b\u093e\u0924\u094d\u0930\u093e\u0913\u0902 \u0928\u0947 \u092d\u0917\u0935\u093e\u0928 \u092e\u0939\u093e\u0935\u0940\u0930 \u0915\u0947 \u091c\u0940\u0935\u0928, \u0909\u0928\u0915\u0947 \u0924\u094d\u092f\u093e\u0917, \u0938\u0924\u094d\u092f, \u0905\u0939\u093f\u0902\u0938\u093e, \u0915\u0930\u0941\u0923\u093e \u090f\u0935\u0902 \u0905\u092a\u0930\u093f\u0917\u094d\u0930\u0939 \u0915\u0947 \u0938\u093f\u0926\u094d\u0927\u093e\u0902\u0924\u094b\u0902 \u092a\u0930 \u092a\u094d\u0930\u0915\u093e\u0936 \u0921\u093e\u0932\u093e\u0964 \ufffd\nThe Times of India +1\n\u0915\u093e\u0930\u094d\u092f\u0915\u094d\u0930\u092e \u092e\u0947\u0902 \u091b\u093e\u0924\u094d\u0930\u093e\u0913\u0902 \u0926\u094d\u0935\u093e\u0930\u093e \u092d\u093e\u0937\u0923, \u092a\u094d\u0930\u0947\u0930\u0915 \u0935\u093f\u091a\u093e\u0930 \u090f\u0935\u0902 \u0938\u093e\u0902\u0938\u094d\u0915\u0943\u0924\u093f\u0915 \u092a\u094d\u0930\u0938\u094d\u0924\u0941\u0924\u093f\u092f\u093e\u0901 \u0926\u0940 \u0917\u0908\u0902\u0964 \u0936\u093f\u0915\u094d\u0937\u093f\u0915\u093e\u0913\u0902 \u0928\u0947 \u091b\u093e\u0924\u094d\u0930\u093e\u0913\u0902 \u0915\u094b \u092d\u0917\u0935\u093e\u0928 \u092e\u0939\u093e\u0935\u0940\u0930 \u0915\u0947 \u0906\u0926\u0930\u094d\u0936\u094b\u0902 \u0915\u094b \u0905\u092a\u0928\u0947 \u0926\u0948\u0928\u093f\u0915 \u091c\u0940\u0935\u0928 \u092e\u0947\u0902 \u0905\u092a\u0928\u093e\u0928\u0947, \u0938\u092d\u0940 \u092a\u094d\u0930\u093e\u0923\u093f\u092f\u094b\u0902 \u0915\u0947 \u092a\u094d\u0930\u0924\u093f \u0926\u092f\u093e \u090f\u0935\u0902 \u0938\u092e\u094d\u092e\u093e\u0928 \u0915\u093e \u092d\u093e\u0935 \u0930\u0916\u0928\u0947 \u0924\u0925\u093e \u0938\u0924\u094d\u092f \u090f\u0935\u0902 \u0905\u0939\u093f\u0902\u0938\u093e \u0915\u0947 \u092e\u093e\u0930\u094d\u0917 \u092a\u0930 \u091a\u0932\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f \u092a\u094d\u0930\u0947\u0930\u093f\u0924 \u0915\u093f\u092f\u093e\u0964\n\u0905\u0902\u0924 \u092e\u0947\u0902 \u0935\u093f\u0926\u094d\u092f\u093e\u0932\u092f \u092a\u0930\u093f\u0935\u093e\u0930 \u0928\u0947 \u092d\u0917\u0935\u093e\u0928 \u092e\u0939\u093e\u0935\u0940\u0930 \u0915\u0947 \u092c\u0924\u093e\u090f \u092e\u093e\u0930\u094d\u0917 \u092a\u0930 \u091a\u0932\u0928\u0947 \u0915\u093e \u0938\u0902\u0915\u0932\u094d\u092a \u0932\u093f\u092f\u093e \u0924\u0925\u093e \u0938\u092d\u0940 \u0915\u0947 \u0938\u0941\u0916, \u0936\u093e\u0902\u0924\u093f \u090f\u0935\u0902 \u0938\u092e\u0943\u0926\u094d\u0927\u093f \u0915\u0940 \u0915\u093e\u092e\u0928\u093e \u0915\u0947 \u0938\u093e\u0925 \u0915\u093e\u0930\u094d\u092f\u0915\u094d\u0930\u092e \u0915\u093e \u0938\u092e\u093e\u092a\u0928 \u0915\u093f\u092f\u093e\u0964", "category": "General", "id": "db8f5d99-c2f6-4a14-810c-34c9085b8f49", "created_at": "2026-07-21T18:00:19.237777+00:00"}]