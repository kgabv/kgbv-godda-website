[{"name": "\u0936\u094d\u0930\u0940\u092e\u0924\u0940 \u0938\u094d\u0928\u0947\u0939\u0932\u0924\u093e \u0915\u0941\u092e\u093e\u0930\u0940", "role": "\u0935\u093e\u0930\u094d\u0921\u0947\u0928 \u090f\u0935\u0902 \u0935\u093f\u091c\u094d\u091e\u093e\u0928 \u0936\u093f\u0915\u094d\u0937\u093f\u0915\u093e", "image_url": "/api/files/kgbv-godda/uploads/cefdb94f-f93d-4e45-a40d-01acdc3134aa.png", "bio": "\u0936\u094d\u0930\u0940\u092e\u0924\u0940 \u0938\u094d\u0928\u0947\u0939\u0932\u0924\u093e \u0915\u0941\u092e\u093e\u0930\u0940 \u0915\u0938\u094d\u0924\u0942\u0930\u092c\u093e \u0917\u093e\u0902\u0927\u0940 \u092c\u093e\u0932\u093f\u0915\u093e \u0935\u093f\u0926\u094d\u092f\u093e\u0932\u092f, \u0917\u094b\u0921\u094d\u0921\u093e \u092e\u0947\u0902 \u0935\u093e\u0930\u094d\u0921\u0947\u0928 \u090f\u0935\u0902 \u0935\u093f\u091c\u094d\u091e\u093e\u0928 \u0936\u093f\u0915\u094d\u0937\u093f\u0915\u093e \u0915\u0947 \u0930\u0942\u092a \u092e\u0947\u0902 \u0915\u093e\u0930\u094d\u092f\u0930\u0924 \u0939\u0948\u0902\u0964 \u0935\u0947 \u0935\u093f\u0926\u094d\u092f\u093e\u0932\u092f \u0915\u0947 \u0906\u0935\u093e\u0938\u0940\u092f \u0935\u093e\u0924\u093e\u0935\u0930\u0923 \u092e\u0947\u0902 \u091b\u093e\u0924\u094d\u0930\u093e\u0913\u0902 \u0915\u0940 \u0938\u0941\u0930\u0915\u094d\u0937\u093e, \u0905\u0928\u0941\u0936\u093e\u0938\u0928, \u0938\u094d\u0935\u093e\u0938\u094d\u0925\u094d\u092f \u090f\u0935\u0902 \u0938\u092e\u0917\u094d\u0930 \u0926\u0947\u0916\u092d\u093e\u0932 \u0938\u0941\u0928\u093f\u0936\u094d\u091a\u093f\u0924 \u0915\u0930\u0928\u0947 \u0915\u0947 \u0938\u093e\u0925-\u0938\u093e\u0925 \u0935\u093f\u091c\u094d\u091e\u093e\u0928 \u0935\u093f\u0937\u092f \u0915\u093e \u092a\u094d\u0930\u092d\u093e\u0935\u0940 \u090f\u0935\u0902 \u0917\u0941\u0923\u0935\u0924\u094d\u0924\u093e\u092a\u0942\u0930\u094d\u0923 \u0936\u093f\u0915\u094d\u0937\u0923 \u092d\u0940 \u0915\u0930\u0924\u0940 \u0939\u0948\u0902\u0964 \u0909\u0928\u0915\u0947 \u092e\u093e\u0930\u094d\u0917\u0926\u0930\u094d\u0936\u0928 \u092e\u0947\u0902 \u091b\u093e\u0924\u094d\u0930\u093e\u090f\u0901 \u0935\u0948\u091c\u094d\u091e\u093e\u0928\u093f\u0915 \u0926\u0943\u0937\u094d\u091f\u093f\u0915\u094b\u0923, \u0905\u0928\u0941\u0936\u093e\u0938\u0928, \u0906\u0924\u094d\u092e\u0935\u093f\u0936\u094d\u0935\u093e\u0938 \u0924\u0925\u093e \u0928\u0948\u0924\u093f\u0915 \u092e\u0942\u0932\u094d\u092f\u094b\u0902 \u0915\u093e \u0935\u093f\u0915\u093e\u0938 \u0915\u0930\u0924\u0940 \u0939\u0948\u0902\u0964 \u0935\u0947 \u091b\u093e\u0924\u094d\u0930\u093e\u0913\u0902 \u0915\u0947 \u0936\u0948\u0915\u094d\u0937\u0923\u093f\u0915, \u0938\u093e\u092e\u093e\u091c\u093f\u0915 \u090f\u0935\u0902 \u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0924\u094d\u0935 \u0935\u093f\u0915\u093e\u0938 \u0915\u0947 \u0932\u093f\u090f \u0928\u093f\u0930\u0902\u0924\u0930 \u0938\u092e\u0930\u094d\u092a\u093f\u0924 \u0939\u0948\u0902\u0964", "category": "teaching", "order": 0, "id": "f4414128-8e28-429e-af57-83e57426bc17", "created_at": "2026-07-21T17:22:53.237775+00:00"}, {"name": "\u0936\u094d\u0930\u0940 \u0939\u0947\u092e\u0902\u0924 \u0915\u0941\u092e\u093e\u0930 \u091d\u093e", "role": "\u0930\u0938\u093e\u092f\u0928 \u0935\u093f\u091c\u094d\u091e\u093e\u0928 (Chemistry) \u0936\u093f\u0915\u094d\u0937\u0915", "image_url": "/api/files/kgbv-godda/uploads/418fdfa8-de62-4511-8537-424b6b86f5a9.png", "bio": "\u0936\u094d\u0930\u0940 \u0939\u0947\u092e\u0902\u0924 \u0915\u0941\u092e\u093e\u0930 \u091d\u093e \u0915\u0938\u094d\u0924\u0942\u0930\u092c\u093e \u0917\u093e\u0902\u0927\u0940 \u092c\u093e\u0932\u093f\u0915\u093e \u0935\u093f\u0926\u094d\u092f\u093e\u0932\u092f, \u0917\u094b\u0921\u094d\u0921\u093e \u092e\u0947\u0902 \u0930\u0938\u093e\u092f\u0928 \u0935\u093f\u091c\u094d\u091e\u093e\u0928 \u0936\u093f\u0915\u094d\u0937\u0915 \u0915\u0947 \u0930\u0942\u092a \u092e\u0947\u0902 \u0915\u093e\u0930\u094d\u092f\u0930\u0924 \u0939\u0948\u0902\u0964 \u0935\u0947 \u091b\u093e\u0924\u094d\u0930\u093e\u0913\u0902 \u0915\u094b \u0930\u0938\u093e\u092f\u0928 \u0935\u093f\u091c\u094d\u091e\u093e\u0928 \u0915\u0947 \u0938\u093f\u0926\u094d\u0927\u093e\u0902\u0924\u094b\u0902 \u090f\u0935\u0902 \u0905\u0935\u0927\u093e\u0930\u0923\u093e\u0913\u0902 \u0915\u094b \u0938\u0930\u0932, \u0935\u094d\u092f\u093e\u0935\u0939\u093e\u0930\u093f\u0915 \u0924\u0925\u093e \u092a\u094d\u0930\u092f\u094b\u0917\u093e\u0924\u094d\u092e\u0915 \u0926\u0943\u0937\u094d\u091f\u093f\u0915\u094b\u0923 \u0938\u0947 \u0938\u092e\u091d\u093e\u0928\u0947 \u0915\u093e \u092a\u094d\u0930\u092f\u093e\u0938 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902\u0964 \u0909\u0928\u0915\u093e \u0909\u0926\u094d\u0926\u0947\u0936\u094d\u092f \u091b\u093e\u0924\u094d\u0930\u093e\u0913\u0902 \u092e\u0947\u0902 \u0935\u0948\u091c\u094d\u091e\u093e\u0928\u093f\u0915 \u0938\u094b\u091a, \u0924\u093e\u0930\u094d\u0915\u093f\u0915 \u0935\u093f\u0936\u094d\u0932\u0947\u0937\u0923 \u0915\u094d\u0937\u092e\u0924\u093e \u0924\u0925\u093e \u0935\u093f\u0937\u092f \u0915\u0947 \u092a\u094d\u0930\u0924\u093f \u0930\u0941\u091a\u093f \u0935\u093f\u0915\u0938\u093f\u0924 \u0915\u0930\u0928\u093e \u0939\u0948\u0964\n\u0935\u0947 \u091b\u093e\u0924\u094d\u0930-\u0915\u0947\u0902\u0926\u094d\u0930\u093f\u0924 \u0936\u093f\u0915\u094d\u0937\u0923 \u092a\u0926\u094d\u0927\u0924\u093f \u092e\u0947\u0902 \u0935\u093f\u0936\u094d\u0935\u093e\u0938 \u0930\u0916\u0924\u0947 \u0939\u0948\u0902 \u0914\u0930 \u092a\u094d\u0930\u092f\u094b\u0917\u094b\u0902, \u0909\u0926\u093e\u0939\u0930\u0923\u094b\u0902 \u0924\u0925\u093e \u0917\u0924\u093f\u0935\u093f\u0927\u093f-\u0906\u0927\u093e\u0930\u093f\u0924 \u0936\u093f\u0915\u094d\u0937\u0923 \u0915\u0947 \u092e\u093e\u0927\u094d\u092f\u092e \u0938\u0947 \u091b\u093e\u0924\u094d\u0930\u093e\u0913\u0902 \u0915\u094b \u0917\u0941\u0923\u0935\u0924\u094d\u0924\u093e\u092a\u0942\u0930\u094d\u0923 \u0936\u093f\u0915\u094d\u0937\u093e \u092a\u094d\u0930\u0926\u093e\u0928 \u0915\u0930\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f \u0928\u093f\u0930\u0902\u0924\u0930 \u092a\u094d\u0930\u092f\u093e\u0938\u0930\u0924 \u0939\u0948\u0902\u0964 \u0909\u0928\u0915\u0947 \u092e\u093e\u0930\u094d\u0917\u0926\u0930\u094d\u0936\u0928 \u092e\u0947\u0902 \u091b\u093e\u0924\u094d\u0930\u093e\u090f\u0901 \u0935\u093f\u091c\u094d\u091e\u093e\u0928 \u0915\u0947 \u092a\u094d\u0930\u0924\u093f \u091c\u093f\u091c\u094d\u091e\u093e\u0938\u093e, \u0906\u0924\u094d\u092e\u0935\u093f\u0936\u094d\u0935\u093e\u0938 \u090f\u0935\u0902 \u0928\u0935\u093e\u091a\u093e\u0930 \u0915\u0940 \u092d\u093e\u0935\u0928\u093e \u0935\u093f\u0915\u0938\u093f\u0924 \u0915\u0930\u0924\u0940 \u0939\u0948\u0902\u0964", "category": "teaching", "order": 0, "id": "bcec9735-0f15-4efe-87eb-c4b187dfc134", "created_at": "2026-07-21T17:28:12.434131+00:00"}, {"name": "\u0936\u094d\u0930\u0940 \u0930\u093e\u0939\u0941\u0932 \u0915\u0941\u092e\u093e\u0930", "role": "\u092d\u0942\u0917\u094b\u0932 (Geography) \u0936\u093f\u0915\u094d\u0937\u0915", "image_url": "/api/files/kgbv-godda/uploads/9b965762-409b-4ba0-97a7-e9959d173ff7.png", "bio": "\u0936\u094d\u0930\u0940 \u0930\u093e\u0939\u0941\u0932 \u0915\u0941\u092e\u093e\u0930 \u0915\u0938\u094d\u0924\u0942\u0930\u092c\u093e \u0917\u093e\u0902\u0927\u0940 \u092c\u093e\u0932\u093f\u0915\u093e \u0935\u093f\u0926\u094d\u092f\u093e\u0932\u092f, \u0917\u094b\u0921\u094d\u0921\u093e \u092e\u0947\u0902 \u092d\u0942\u0917\u094b\u0932 \u0936\u093f\u0915\u094d\u0937\u0915 \u0915\u0947 \u0930\u0942\u092a \u092e\u0947\u0902 \u0915\u093e\u0930\u094d\u092f\u0930\u0924 \u0939\u0948\u0902\u0964 \u0935\u0947 \u091b\u093e\u0924\u094d\u0930\u093e\u0913\u0902 \u0915\u094b \u092d\u0942\u0917\u094b\u0932 \u0935\u093f\u0937\u092f \u0915\u0940 \u092d\u094c\u0924\u093f\u0915, \u092e\u093e\u0928\u0935 \u090f\u0935\u0902 \u092a\u0930\u094d\u092f\u093e\u0935\u0930\u0923\u0940\u092f \u0905\u0935\u0927\u093e\u0930\u0923\u093e\u0913\u0902 \u0915\u094b \u0938\u0930\u0932, \u0930\u094b\u091a\u0915 \u090f\u0935\u0902 \u0935\u094d\u092f\u093e\u0935\u0939\u093e\u0930\u093f\u0915 \u0924\u0930\u0940\u0915\u0947 \u0938\u0947 \u0938\u092e\u091d\u093e\u0928\u0947 \u0915\u093e \u092a\u094d\u0930\u092f\u093e\u0938 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902\u0964 \u092e\u093e\u0928\u091a\u093f\u0924\u094d\u0930, \u091a\u093e\u0930\u094d\u091f, \u092e\u0949\u0921\u0932 \u0924\u0925\u093e \u0917\u0924\u093f\u0935\u093f\u0927\u093f-\u0906\u0927\u093e\u0930\u093f\u0924 \u0936\u093f\u0915\u094d\u0937\u0923 \u0915\u0947 \u092e\u093e\u0927\u094d\u092f\u092e \u0938\u0947 \u0935\u0947 \u0935\u093f\u0937\u092f \u0915\u094b \u091c\u0940\u0935\u0928 \u0938\u0947 \u091c\u094b\u0921\u093c\u0915\u0930 \u092a\u094d\u0930\u0938\u094d\u0924\u0941\u0924 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902\u0964\n\u0935\u0947 \u091b\u093e\u0924\u094d\u0930\u093e\u0913\u0902 \u092e\u0947\u0902 \u092a\u0930\u094d\u092f\u093e\u0935\u0930\u0923 \u0938\u0902\u0930\u0915\u094d\u0937\u0923, \u092a\u094d\u0930\u093e\u0915\u0943\u0924\u093f\u0915 \u0938\u0902\u0938\u093e\u0927\u0928\u094b\u0902 \u0915\u0947 \u092a\u094d\u0930\u0924\u093f \u091c\u093e\u0917\u0930\u0942\u0915\u0924\u093e, \u0924\u093e\u0930\u094d\u0915\u093f\u0915 \u0938\u094b\u091a \u0924\u0925\u093e \u0935\u093f\u0936\u094d\u0932\u0947\u0937\u0923\u093e\u0924\u094d\u092e\u0915 \u0915\u094d\u0937\u092e\u0924\u093e \u0935\u093f\u0915\u0938\u093f\u0924 \u0915\u0930\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f \u0928\u093f\u0930\u0902\u0924\u0930 \u092a\u094d\u0930\u0947\u0930\u093f\u0924 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902\u0964 \u0909\u0928\u0915\u093e \u0909\u0926\u094d\u0926\u0947\u0936\u094d\u092f \u0917\u0941\u0923\u0935\u0924\u094d\u0924\u093e\u092a\u0942\u0930\u094d\u0923 \u0936\u093f\u0915\u094d\u0937\u093e \u0915\u0947 \u0938\u093e\u0925 \u091b\u093e\u0924\u094d\u0930\u093e\u0913\u0902 \u092e\u0947\u0902 \u0906\u0924\u094d\u092e\u0935\u093f\u0936\u094d\u0935\u093e\u0938, \u091c\u093f\u091c\u094d\u091e\u093e\u0938\u093e \u0914\u0930 \u091c\u093f\u092e\u094d\u092e\u0947\u0926\u093e\u0930 \u0928\u093e\u0917\u0930\u093f\u0915 \u092c\u0928\u0928\u0947 \u0915\u0940 \u092d\u093e\u0935\u0928\u093e \u0915\u093e \u0935\u093f\u0915\u093e\u0938 \u0915\u0930\u0928\u093e \u0939\u0948\u0964", "category": "teaching", "order": 0, "id": "f8d5c76d-6eab-4b5a-9f40-2df272d651ba", "created_at": "2026-07-21T17:29:22.101859+00:00"}, {"name": "\u0936\u094d\u0930\u0940 \u091c\u092f\u0915\u0943\u0937\u094d\u0923 \u092f\u093e\u0926\u0935", "role": "\u0905\u0902\u0917\u094d\u0930\u0947\u091c\u093c\u0940 \u0936\u093f\u0915\u094d\u0937\u0915", "image_url": "/api/files/kgbv-godda/uploads/3db253d3-4757-43fa-9533-22bed8f6217f.png", "bio": "\u0936\u094d\u0930\u0940 \u091c\u092f\u0915\u0943\u0937\u094d\u0923 \u092f\u093e\u0926\u0935 \u0915\u0938\u094d\u0924\u0942\u0930\u092c\u093e \u0917\u093e\u0902\u0927\u0940 \u092c\u093e\u0932\u093f\u0915\u093e \u0935\u093f\u0926\u094d\u092f\u093e\u0932\u092f, \u0917\u094b\u0921\u094d\u0921\u093e \u092e\u0947\u0902 \u0905\u0902\u0917\u094d\u0930\u0947\u091c\u093c\u0940 \u0936\u093f\u0915\u094d\u0937\u0915 \u0915\u0947 \u0930\u0942\u092a \u092e\u0947\u0902 \u0915\u093e\u0930\u094d\u092f\u0930\u0924 \u0939\u0948\u0902\u0964 \u0935\u0947 \u091b\u093e\u0924\u094d\u0930\u093e\u0913\u0902 \u0915\u094b \u0905\u0902\u0917\u094d\u0930\u0947\u091c\u093c\u0940 \u092d\u093e\u0937\u093e \u0915\u0947 \u091a\u093e\u0930\u094b\u0902 \u0915\u094c\u0936\u0932\u2014Listening, Speaking, Reading \u090f\u0935\u0902 Writing (LSRW)\u2014\u0915\u093e \u092a\u094d\u0930\u092d\u093e\u0935\u0940 \u0935\u093f\u0915\u093e\u0938 \u0915\u0930\u093e\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f \u0938\u092e\u0930\u094d\u092a\u093f\u0924 \u0939\u0948\u0902\u0964 \u0935\u0947 \u0938\u0930\u0932, \u0938\u0902\u0935\u093e\u0926\u093e\u0924\u094d\u092e\u0915 \u090f\u0935\u0902 \u0917\u0924\u093f\u0935\u093f\u0927\u093f-\u0906\u0927\u093e\u0930\u093f\u0924 \u0936\u093f\u0915\u094d\u0937\u0923 \u092a\u0926\u094d\u0927\u0924\u093f \u0915\u0947 \u092e\u093e\u0927\u094d\u092f\u092e \u0938\u0947 \u0905\u0902\u0917\u094d\u0930\u0947\u091c\u093c\u0940 \u0915\u094b \u0938\u0939\u091c, \u0930\u094b\u091a\u0915 \u0914\u0930 \u0935\u094d\u092f\u0935\u0939\u093e\u0930\u093f\u0915 \u0930\u0942\u092a \u092e\u0947\u0902 \u092a\u0922\u093c\u093e\u0924\u0947 \u0939\u0948\u0902\u0964\n\u0935\u0947 \u091b\u093e\u0924\u094d\u0930\u093e\u0913\u0902 \u092e\u0947\u0902 \u092a\u094d\u0930\u092d\u093e\u0935\u0940 \u0938\u0902\u091a\u093e\u0930 \u0915\u094c\u0936\u0932, \u0938\u0939\u0940 \u0909\u091a\u094d\u091a\u093e\u0930\u0923, \u0935\u094d\u092f\u093e\u0915\u0930\u0923 \u0915\u0940 \u092e\u091c\u092c\u0942\u0924 \u0938\u092e\u091d \u0924\u0925\u093e \u0906\u0924\u094d\u092e\u0935\u093f\u0936\u094d\u0935\u093e\u0938 \u0935\u093f\u0915\u0938\u093f\u0924 \u0915\u0930\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f \u0928\u093f\u0930\u0902\u0924\u0930 \u092a\u094d\u0930\u0947\u0930\u093f\u0924 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902\u0964 \u0909\u0928\u0915\u093e \u0909\u0926\u094d\u0926\u0947\u0936\u094d\u092f \u091b\u093e\u0924\u094d\u0930\u093e\u0913\u0902 \u0915\u094b \u0917\u0941\u0923\u0935\u0924\u094d\u0924\u093e\u092a\u0942\u0930\u094d\u0923 \u092d\u093e\u0937\u093e \u0936\u093f\u0915\u094d\u0937\u093e \u092a\u094d\u0930\u0926\u093e\u0928 \u0915\u0930 \u0909\u0928\u094d\u0939\u0947\u0902 \u0909\u091a\u094d\u091a \u0936\u093f\u0915\u094d\u0937\u093e, \u092a\u094d\u0930\u0924\u093f\u092f\u094b\u0917\u0940 \u092a\u0930\u0940\u0915\u094d\u0937\u093e\u0913\u0902 \u0924\u0925\u093e \u092d\u0935\u093f\u0937\u094d\u092f \u0915\u0940 \u091a\u0941\u0928\u094c\u0924\u093f\u092f\u094b\u0902 \u0915\u0947 \u0932\u093f\u090f \u0938\u0915\u094d\u0937\u092e \u092c\u0928\u093e\u0928\u093e \u0939\u0948\u0964", "category": "teaching", "order": 0, "id": "5671ae07-85ce-4b77-8749-21d6467c3c31", "created_at": "2026-07-21T17:31:56.538236+00:00"}]