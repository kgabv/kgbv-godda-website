8\u0928 \u0915\u0947 \u0938\u093e\u0925\u0964", "photo_url": "/api/files/kgbv-godda/uploads/152f65b2-0494-4306-90c8-3f1f550d9371.jpg"}, "updated_at": "2026-07-21T14:47:16.306074+00:00"}, {"key": "stats", "value": {"students": 474, "teachers": 30, "classes": 7, "awards": 45}, "updated_at": "2026-07-21T13:02:50.391782+00:00"}, {"key": "social", "value": {"facebook": "", "instagram": "", "twitter": "", "youtube": "https://www.youtube.com/@kgbvgodda", "whatsapp": ""}, "updated_at": "2026-07-21T11:32:26.204Z"}, {"key": "footer", "value": {"about_text": "\u0936\u093f\u0915\u094d\u0937\u093e \u2022 \u0938\u0902\u0938\u094d\u0915\u093e\u0930 \u2022 \u0906\u0924\u094d\u092e\u0928\u093f\u0930\u094d\u092d\u0930\u0924\u093e \u2014 \u092c\u093e\u0932\u093f\u0915\u093e\u0913\u0902 \u0915\u0947 \u0932\u093f\u090f \u090f\u0915 \u0938\u0941\u0930\u0915\u094d\u0937\u093f\u0924 \u090f\u0935\u0902 \u0917\u0941\u0923\u0935\u0924\u094d\u0924\u093e\u092a\u0942\u0930\u094d\u0923 \u0935\u093f\u0926\u094d\u092f\u093e\u0932\u092f\u0964", "copyright": "\u00a9 KGBV Godda. \u0938\u0930\u094d\u0935\u093e\u0927\u093f\u0915\u093e\u0930 \u0938\u0941\u0930\u0915\u094d\u0937\u093f\u0924\u0964"}, "updated_at": "2026-07-21T11:32:26.204Z"}, {"key": "seo", "value": {"title": "\u0915\u0938\u094d\u0924\u0942\u0930\u092c\u093e \u0917\u093e\u0902\u0927\u0940 \u092c\u093e\u0932\u093f\u0915\u093e \u0935\u093f\u0926\u094d\u092f\u093e\u0932\u092f, \u0917\u094b\u0921\u094d\u0921\u093e | KGBV Godda", "description": "KGBV Godda \u2014 \u091d\u093e\u0930\u0916\u0902\u0921 \u0936\u093f\u0915\u094d\u0937\u093e \u0935\u093f\u092d\u093e\u0917 \u0926\u094d\u0935\u093e\u0930\u093e \u0938\u0902\u091a\u093e\u0932\u093f\u0924 \u092a\u0942\u0930\u094d\u0923 \u0906\u0935\u093e\u0938\u0940\u092f \u092c\u093e\u0932\u093f\u0915\u093e \u0935\u093f\u0926\u094d\u092f\u093e\u0932\u092f\u0964 \u0915\u0915\u094d\u0937\u093e VI-XII\u0964", "keywords": "KGBV, Kasturba Gandhi, Balika Vidyalaya, Godda, Jharkhand"}, "updated_at": "2026-07-21T11:32:26.204Z"}, {"key": "admission", "value": {"heading": "\u092a\u094d\u0930\u0935\u0947\u0936 \u091c\u093e\u0928\u0915\u093e\u0930\u0940", "intro": "\u0915\u0915\u094d\u0937\u093e VI \u0938\u0947 XII \u0924\u0915 \u0915\u0940 \u091b\u093e\u0924\u094d\u0930\u093e\u0913\u0902 \u0915\u0947 \u0932\u093f\u090f \u0928\u093f\u0903\u0936\u0941\u0932\u094d\u0915 \u092a\u094d\u0930\u0935\u0947\u0936\u0964", "eligibility": "\u0917\u094d\u0930\u093e\u092e\u0940\u0923/\u0935\u0902\u091a\u093f\u0924 \u0935\u0930\u094d\u0917 \u0915\u0940 \u092c\u093e\u0932\u093f\u0915\u093e\u090f\u0901 | \u0906\u092f\u0941 \u0938\u0940\u092e\u093e: \u0915\u0915\u094d\u0937\u093e \u0905\u0928\u0941\u0938\u093e\u0930 | \u0906\u0927\u093e\u0930 \u0915\u093e\u0930\u094d\u0921 \u0906\u0935\u0936\u094d\u092f\u0915 | \u091c\u093e\u0924\u093f \u092a\u094d\u0930\u092e\u093e\u0923 \u092a\u0924\u094d\u0930 (\u092f\u0926\u093f \u0932\u093e\u0917\u0942) | \u0938\u094d\u0925\u093e\u0928\u093e\u0902\u0924\u0930\u0923 \u092a\u094d\u0930\u092e\u093e\u0923 \u092a\u0924\u094d\u0930 (TC) | \u0905\u0902\u0924\u093f\u092e \u0915\u0915\u094d\u0937\u093e \u0915\u0940 \u0905\u0902\u0915\u0924\u093e\u0932\u093f\u0915\u093e", "process": "\u0935\u093f\u0926\u094d\u092f\u093e\u0932\u092f \u0915\u093e\u0930\u094d\u092f\u093e\u0932\u092f \u0938\u0947 \u0906\u0935\u0947\u0926\u0928 \u092a\u0924\u094d\u0930 \u092a\u094d\u0930\u093e\u092a\u094d\u0924 \u0915\u0930\u0947\u0902, \u0906\u0935\u0936\u094d\u092f\u0915 \u0926\u0938\u094d\u0924\u093e\u0935\u0947\u091c\u094b\u0902 \u0915\u0947 \u0938\u093e\u0925 \u091c\u092e\u093e \u0915\u0930\u0947\u0902\u0964 \u091a\u092f\u0928 \u092a\u094d\u0930\u0915\u094d\u0930\u093f\u092f\u093e \u0915\u0947 \u092c\u093e\u0926 \u092a\u094d\u0930\u0935\u0947\u0936 \u0938\u0941\u0928\u093f\u0936\u094d\u091a\u093f\u0924 \u0939\u094b\u0917\u093e\u0964"}, "updated_at": "2026-07-21T11:32:26.204Z"}, {"key": "academics", "value": {"heading": "\u0936\u093f\u0915\u094d\u0937\u093e (\u0915\u0915\u094d\u0937\u093e VI-XII)", "intro": "\u0939\u092e\u093e\u0930\u0940 \u0935\u093f\u0926\u094d\u092f\u093e\u0932\u092f \u091d\u093e\u0930\u0916\u0902\u0921 \u0936\u0948\u0915\u094d\u0937\u093f\u0915 \u092c\u094b\u0930\u094d\u0921 (JAC) \u092a\u093e\u0920\u094d\u092f\u0915\u094d\u0930\u092e \u092a\u0930 \u0906\u0927\u093e\u0930\u093f\u0924 \u0909\u091a\u094d\u091a-\u0917\u0941\u0923\u0935\u0924\u094d\u0924\u093e \u0915\u0940 \u0936\u093f\u0915\u094d\u0937\u093e \u092a\u094d\u0930\u0926\u093e\u0928 \u0915\u0930\u0924\u093e \u0939\u0948\u0964"}, "updated_at": "2026-07-21T11:32:26.204Z"}, {"key": "hostel", "value": {"heading": "\u0906\u0935\u093e\u0938\u0940\u092f \u091b\u093e\u0924\u094d\u0930\u093e\u0935\u093e\u0938", "body": "\u0938\u0941\u0930\u0915\u094d\u0937\u093f\u0924, \u0938\u094d\u0935\u091a\u094d\u091b \u090f\u0935\u0902 \u0906\u0930\u093e\u092e\u0926\u093e\u092f\u0915 \u091b\u093e\u0924\u094d\u0930\u093e\u0935\u093e\u0938 \u0938\u0941\u0935\u093f\u0927\u093e\u0964 24\u00d77 \u0935\u093e\u0930\u094d\u0921\u0928 \u0909\u092a\u0938\u094d\u0925\u093f\u0924\u093f, \u092a\u094c\u0937\u094d\u091f\u093f\u0915 \u092d\u094b\u091c\u0928, \u091a\u093f\u0915\u093f\u0924\u094d\u0938\u093e \u0938\u0939\u093e\u092f\u0924\u093e \u090f\u0935\u0902 \u0905\u0927\u094d\u092f\u092f\u0928 \u0915\u0915\u094d\u0937\u0964"}, "updated_at": "2026-07-21T11:32:26.204Z"}, {"key": "branding", "value": {"logo_url": "https://customer-assets-wrfwihn1.emergentagent.net/job_e3f9b288-4ca0-4b1b-858c-48bc26649331/artifacts/7brhlrkg_IMG_20260704_154418.png", "favicon_url": "https://customer-assets-wrfwihn1.emergentagent.net/job_e3f9b288-4ca0-4b1b-858c-48bc26649331/artifacts/7brhlrkg_IMG_20260704_154418.png", "school_name": "\u0915\u0938\u094d\u0924\u0942\u0930\u092c\u093e \u0917\u093e\u0902\u0927\u0940 \u092c\u093e\u0932\u093f\u0915\u093e \u0935\u093f\u0926\u094d\u092f\u093e\u0932\u092f", "school_name_short": "\u0917\u094b\u0921\u094d\u0921\u093e, \u091d\u093e\u0930\u0916\u0902\u0921", "tagline": "\u0936\u093f\u0915\u094d\u0937\u093e \u00b7 \u0938\u0902\u0938\u094d\u0915\u093e\u0930 \u00b7 \u0906\u0924\u094d\u092e\u0928\u093f\u0930\u094d\u092d\u0930\u0924\u093e"}, "updated_at": "2026-07-21T11:32:26.204Z"}, {"key": "theme", "value": {"primary": "#e39c40", "secondary": "#226e0f", "accent": "#E1F3FB", "background": "#F5F9FE"}, "updated_at": "2026-07-21T15:47:27.083265+00:00"}, {"key": "vidyalaya_parichay", "value": {"heading": "\u0939\u092e\u093e\u0930\u0947 \u0935\u093f\u0926\u094d\u092f\u093e\u0932\u092f \u0915\u0947 \u092c\u093e\u0930\u0947 \u092e\u0947\u0902", "body": "\u0915\u0938\u094d\u0924\u0942\u0930\u092c\u093e \u0917\u093e\u0902\u0927\u0940 \u092c\u093e\u0932\u093f\u0915\u093e \u0935\u093f\u0926\u094d\u092f\u093e\u0932\u092f (KGBV), \u0917\u094b\u0921\u094d\u0921\u093e \u090f\u0915 \u092a\u0942\u0930\u094d\u0923 \u0906\u0935\u093e\u0938\u0940\u092f \u0935\u093f\u0926\u094d\u092f\u093e\u0932\u092f \u0939\u0948 \u091c\u094b \u091d\u093e\u0930\u0916\u0902\u0921 \u0936\u093f\u0915\u094d\u0937\u093e \u0935\u093f\u092d\u093e\u0917 \u0915\u0947 \u0905\u0902\u0924\u0930\u094d\u0917\u0924 \u0938\u0902\u091a\u093e\u0932\u093f\u0924 \u0939\u0948\u0964 \u092f\u0939\u093e\u0901 \u0915\u0947\u0935\u0932 \u092c\u093e\u0932\u093f\u0915\u093e\u0913\u0902 \u0915\u094b \u0915\u0915\u094d\u0937\u093e VI \u0938\u0947 XII \u0924\u0915 \u0928\u093f\u0903\u0936\u0941\u0932\u094d\u0915 \u0917\u0941\u0923\u0935\u0924\u094d\u0924\u093e\u092a\u0942\u0930\u094d\u0923 \u0936\u093f\u0915\u094d\u0937\u093e \u092a\u094d\u0930\u0926\u093e\u0928 \u0915\u0940 \u091c\u093e\u0924\u0940 \u0939\u0948\u0964 \u0935\u093f\u0926\u094d\u092f\u093e\u0932\u092f \u092c\u093e\u0932\u093f\u0915\u093e\u0913\u0902 \u0915\u094b \u0936\u093f\u0915\u094d\u0937\u093e, \u0938\u0902\u0938\u094d\u0915\u093e\u0930, \u0905\u0928\u0941\u0936\u093e\u0938\u0928, \u0938\u0941\u0930\u0915\u094d\u0937\u093e \u090f\u0935\u0902 \u0906\u0924\u094d\u092e\u0928\u093f\u0930\u094d\u092d\u0930\u0924\u093e \u0915\u0940 \u0926\u093f\u0936\u093e \u092e\u0947\u0902 \u0924\u0948\u092f\u093e\u0930 \u0915\u0930\u0924\u093e \u0939\u0948\u0964", "image_url": "/api/files/kgbv-godda/uploads/3e93dfdc-cce2-4c50-a782-5723bd706554.jpg"}, "updated_at": "2026-07-21T15:49:10.404777+00:00"}]