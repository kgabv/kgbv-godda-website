{
  "name": "kgbv-godda-website-fullstack",
  "version": "1.0.0",
  "description": "Fullstack applet for KGBV Godda",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "postinstall": "npm install --prefix frontend --legacy-peer-deps",
    "build": "npm run build --prefix frontend",
    "dev": "/app/applet/backend/venv/bin/python -m uvicorn server:app --app-dir /app/applet/backend --host 0.0.0.0 --port 3000",
    "start": "/app/applet/backend/venv/bin/python -m uvicorn server:app --app-dir /app/applet/backend --host 0.0.0.0 --port 3000",
    "lint": "echo 'No linting required'"
  },
  "dependencies": {
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "cookie-parser": "^1.4.6",
    "multer": "^1.4.5-lts.1",
    "dotenv": "^16.4.5",
    "uuid": "^9.0.1"
  }
}
